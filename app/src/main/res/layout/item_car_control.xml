<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp"
    android:background="#000000">

    <!-- 車輛名稱 -->
    <TextView
        android:id="@+id/tv_car_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Model S"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:textStyle="bold"/>

    <!-- 控制按鈕橫向排列 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_gravity="center">

        <!-- 前備箱 -->
        <LinearLayout
            android:id="@+id/btn_front_trunk"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="3dp"
            android:gravity="center"
            android:background="@drawable/btn_background"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_front_trunk_status"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/fclose"/>

        </LinearLayout>

        <!-- 開鎖/上鎖 -->
        <LinearLayout
            android:id="@+id/btn_lock_unlock"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="3dp"
            android:gravity="center"
            android:background="@drawable/btn_background"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_lock_status"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/locked"/>

        </LinearLayout>

        <!-- 後備箱 -->
        <LinearLayout
            android:id="@+id/btn_rear_trunk"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="3dp"
            android:gravity="center"
            android:background="@drawable/btn_background"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_rear_trunk_status"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/bclose"/>

        </LinearLayout>

    </LinearLayout>
    <!-- 連接狀態 -->
    <TextView
            android:id="@+id/tv_connection_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未連接"
            android:textColor="@android:color/secondary_text_dark"
            android:textSize="11sp"
            android:layout_marginTop="10dp"
            android:padding="2dp"/>


</LinearLayout> 